# ─── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# ─── Milvus (vector DB) ──────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=agent_response_pairs

# ─── Embedding model (HuggingFace, runs locally on CPU) ──────────────────────
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768

# ─── Dataset ─────────────────────────────────────────────────────────────────
# Absolute path to your conversations.json file
DATASET_PATH=/path/to/conversations.json

# ─── Agent tuning ────────────────────────────────────────────────────────────
REACT_MAX_DEPTH=3
CONTEXT_WINDOW=3
THREAD_MAX_PAIRS=4

# ─── API server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8888
API_BASE_URL=http://localhost:8888

# ─── Evaluation (optional overrides) ─────────────────────────────────────────
# TEST_RATIO=0.2
# SPLIT_SEED=7
# REL_THRESHOLD=0.62
# JUDGE_PASS=4
